{
    "manifest_version": 3,
    "name": "__MSG_extName__",
    "version": "1.0",
    "description": "__MSG_extDesc__",
    "default_locale": "en",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "icons": {
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "scripts/content.js"
            ],
            "css": [
                "scripts/styles.css"
            ],
            "run_at": "document_start",
            "all_frames": true,
            "match_about_blank": true
        }
    ]
}